{
  "name": "decky-renodx",
  "version": "0.0.7",
  "description": "Decky Loader plugin for RenoDX, AutoHDR fallback launch setup, and Proton HDR helpers",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "node scripts/test.js",
    "test:backend": "python -m unittest tests.test_backend_mocks",
    "test:types": "tsc --noEmit --skipLibCheck",
    "package": "python scripts/create_zip.py",
    "release": "node scripts/release.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Feelsrat/decky-renodx.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "hdr",
    "renodx",
    "proton",
    "steam-deck",
    "deck"
  ],
  "author": "Feelsrat",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/Feelsrat/decky-renodx/issues"
  },
  "homepage": "https://github.com/Feelsrat/decky-renodx#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
